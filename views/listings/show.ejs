<% layout("layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<body> 
    <h3><%= listing.title %></h3>

    <div class="card listing-card">
        <div class="card" style="width: 18rem;">
            
            <img
              src="<%= listing.image.url %>"
              class="card-img-top"
              alt="listing_image"
            >

            <div class="card-body">
                <p>
                    <i>
                        Owned by: 
                        <%= listing.owner ? listing.owner.username : "Unknown" %>
                    </i>
                </p>

                <p>
                    <%= listing.description %><br>
                    &#8377 <%= listing.price.toLocaleString("en-IN") %><br>
                </p> 

                <p><%= listing.location %></p>
                <p><%= listing.country %></p>
            </div>
        </div>
    </div>

    <br>

    <!-- ================= OWNER CONTROLS ================= -->
    <% if (currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %> 
        <div class="btns">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit</a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display:inline;">
                <button class="btn btn-dark">Delete</button>
            </form>
        </div>
    <% } %>

    <hr>

    <!-- ================= REVIEW FORM ================= -->
    <% if (currentUser) { %>
        <h4>Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">

            <fieldset class="starability-slot">
  <legend>Rating:</legend>

  <!-- ✅ Default (no star selected) -->
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="" checked />

  <input type="radio" name="review[rating]" value="1" />
  <label for="rate1">1 star</label>

  <input type="radio" id="rate2" name="review[rating]" value="2" />
  <label for="rate2">2 stars</label>

  <input type="radio" id="rate3" name="review[rating]" value="3" />
  <label for="rate3">3 stars</label>

  <input type="radio" id="rate4" name="review[rating]" value="4" />
  <label for="rate4">4 stars</label>

  <input type="radio" id="rate5" name="review[rating]" value="5" />
  <label for="rate5">5 stars</label>
</fieldset>

            <!-- COMMENT -->
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comment</label>
                <textarea 
                    name="review[comment]" 
                    id="comment" 
                    cols="30" 
                    rows="5" 
                    class="form-control" 
                    required>
                </textarea>   
                <div class="invalid-feedback">Please enter a comment!</div>
            </div>

            <button class="btn btn-outline-dark">Submit</button>
        </form>
    <% } %>

    <hr>

    <!-- ================= ALL REVIEWS ================= -->
<% if (listing.reviews.length > 0) { %>
       
    <div class="row">
         <p><b>All Reviews</b></p>

        <% for (let review of listing.reviews) { %>

            <div class="card col-5 ms-3 mb-3">
                <div class="card-body">

                    <h5 class="card-title">
                        <%= review.author ? review.author.username : "Anonymous" %>
                    </h5>

                    <p class="card-text"><%= review.comment %></p>

                    <p class="card-text">Rating: <%= review.rating %> stars</p>

                    <p class="starability-result" data-rating="<%= review.rating %>">
                        Rated: <%= review.rating %> stars
                    </p>

                </div>

                <% if (currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-dark btn-sm">Delete Review</button>
                    </form>
                <% } %>

            </div>

        <% } %>
    </div>

<% } %>
<div class="col-8 offset-3 mb-3">

    <h3>Where you can find this listing</h3>
    <div id="map"></div>
   
</div>


</body>

<script src="/js/map.js"></script>